<header>
    {% include 'partials/_promotion.html.twig' %}

    <nav class="{% if app.request.attributes.get('_route') =='about' %}
                bg-em-blue 
                {% elseif app.request.attributes.get('_route') =='contact' %}
                bg-em-white 
                {% elseif app.request.attributes.get('_route') =='projets' %}
                bg-em-pink 
                {% elseif app.request.attributes.get('_route') =='posts' %}
                bg-em-violet
                {% elseif app.request.attributes.get('_route') =='show' %}
                bg-em-violet
                {% elseif app.request.attributes.get('_route') =='blog' %}
                bg-green-100
                {% elseif app.request.attributes.get('_route') =='donate' %}
                bg-white
                {% else  %}
                    bg-em-yellow 
                {% endif %}
                border-gray-200 px-4 lg:px-6 py-2.5">
        <div class="flex flex-wrap items-center justify-between max-w-screen-xl mx-auto">
            <a href="/" class="flex items-center">
                <img src="{{ absolute_url('/images/logo-betsaleel-long.svg')}}" class="hidden h-6 mr-3 md:flex sm:h-9" alt="Betsaleel Logo" />
                <img src="{{ absolute_url('/images/logo-betsaleel.svg')}}" class="h-6 mr-3 md:hidden sm:h-9" alt="Betsaleel Logo" />
            </a>
            <div class="flex items-center lg:order-2">
                {# <a href="#" class="text-gray-800 hover:bg-gray-50 focus:ring-4 focus:ring-gray-300 font-medium rounded-lg text-sm px-4 lg:px-5 py-2 lg:py-2.5 mr-2 ring-gray-800">Log in</a> #}
                <a href="{{ path('donate') }}" class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-4 lg:px-5 py-2 lg:py-2.5 mr-2 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800">Soutenir</a>
                <button data-collapse-toggle="mobile-menu-2" type="button" class="inline-flex items-center p-2 ml-1 text-sm text-gray-500 rounded-lg lg:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 -controls="mobile-menu-2" aria-expanded="false">
                    <span class="sr-only">Open main menu</span>
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
                    <svg class="hidden w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            <div class="items-center justify-between hidden w-full lg:flex lg:w-auto lg:order-1" id="mobile-menu-2">
                <ul class="flex flex-col mt-4 font-medium lg:flex-row lg:space-x-8 lg:mt-0">
                    <li>
                        <a href="/" class="block py-2 pl-3 pr-4 rounded lg:bg-transparent 
                         {% if app.request.attributes.get('_route') =='home' %}
                           transition delay-150 duration-300 text-red-700 hover:font-bold 
                           {% else %}
                             text-em-green lg:hover:text-blue-700
                         {% endif %}  
                        lg:p-0 " aria-current="page">Home</a>
                    </li>
                    <li>
                        <a href="{{ path('about') }}" class="block py-2 pl-3 pr-4 rounded lg:bg-transparent 
                         {% if app.request.attributes.get('_route') =='about' %}
                           transition delay-150 duration-300 text-red-700 hover:font-bold 
                           {% else %}
                             text-em-green lg:hover:text-blue-700
                         {% endif %}  
                        lg:p-0 " aria-current="page">A propos</a>
                    </li>
                    <li>
                        <a href="{{ path('projets') }}" class="block py-2 pl-3 pr-4 rounded lg:bg-transparent 
                         {% if app.request.attributes.get('_route') =='projets' %}
                           transition delay-150 duration-300 text-red-700 hover:font-bold 
                           {% else %}
                             text-em-green lg:hover:text-blue-700
                         {% endif %}  
                        lg:p-0 " aria-current="page">Projets</a>
                    </li>
                    <li>
                        <a href="{{ path('contact') }}" class="block py-2 pl-3 pr-4 rounded lg:bg-transparent 
                         {% if app.request.attributes.get('_route') =='contact' %}
                           transition delay-150 duration-300 text-red-700 hover:font-bold 
                           {% else %}
                             text-em-green lg:hover:text-blue-700
                         {% endif %}  
                        lg:p-0 " aria-current="page">Contact</a>
                    </li>

                    
                </ul>
            </div>
        </div>
    </nav>
</header>